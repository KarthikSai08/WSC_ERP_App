{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\karthik;Database=WSC_App;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "JWT": {
    "Key": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!WSC2025",
    "Issuer": "WSC.Gateway",
    "Audience": "WSC.App",
    "ExpiryMinutes": "60",
    "RefreshTokenDays": "7"
  },

  "Services": {
    "CRM": "https://localhost:7238",
    "Store": "https://localhost:7126",
    "Delivery": "https://localhost:7023"
  },

  "Redis": {
    "ConnectionString": "localhost:6379"
  },

  "AllowedOrigins": "http://localhost:3000",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "WSC.Gateway.API"
    }
  },

  "AllowedHosts": "*"
}
